# Copy to .env and fill in locally. Never commit .env.

# Path to your Obsidian vault folder on disk
VAULT_PATH=/home/yourname/Obsidian/MyBrain

# Vault OS — comma-separated absolute paths to project repos to scan nightly
VAULT_OS_REPOS=/home/yourname/projects/repo1,/home/yourname/projects/repo2

# Screenpipe local API (default port — only change if you changed it)
SCREENPIPE_URL=http://localhost:3030/search

# AI backend: "ollama" (local, private), "openai" (cloud), or "claude" (Anthropic)
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3

# Only required when AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Only required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5
